@model IEnumerable<StudentManagementSystem.Models.StudentReportCard>
@{
    ViewData["Title"] = "Print Result";
    var type        = ViewBag.Type as string ?? "EndOfYear";
    var sessions    = ViewBag.Sessions as List<string> ?? new List<string>();
    var classes     = ViewBag.Classes  as List<string> ?? new List<string>();
    var sections    = ViewBag.Sections as List<string> ?? new List<string>();
    var terms       = ViewBag.Terms    as List<string> ?? new List<string>();

    var titles = new Dictionary<string, (string Icon, string Label, string Desc)>
    {
        ["EndOfYear"]     = ("fa-trophy",       "End of Year Result",  "Generate and print annual result cards for all students."),
        ["Monthly"]       = ("fa-calendar-day", "Monthly Result",      "Print monthly assessment results by class and section."),
        ["MarksSheet"]    = ("fa-table-list",   "Marks Sheet",         "Print a consolidated marks sheet for the selected class."),
        ["CommentsSheet"] = ("fa-comment-dots", "Comments Sheet",      "Print teacher comments and remarks for each student."),
    };

    var (icon, label, desc) = titles.ContainsKey(type) ? titles[type] : titles["EndOfYear"];
}

<div class="card border-0 shadow-sm no-print mb-4">
    <!-- Header -->
    <div class="card-header bg-info text-white py-3 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <i class="fas @icon fs-4"></i>
            <div>
                <h5 class="mb-0 fw-bold">@label</h5>
                <small class="opacity-75">@desc</small>
            </div>
        </div>
        @if (Model != null && Model.Any())
        {
            <button onclick="window.print()" class="btn btn-light btn-sm px-4 fw-bold">
                <i class="fas fa-print me-2"></i>Print All Result Cards
            </button>
        }
    </div>

    <div class="card-body p-4">
        <!-- Filter Form -->
        <form asp-action="PrintResult" method="get" class="mb-0">
            <input type="hidden" name="type" value="@type" />
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Session</label>
                    <select name="session" class="form-select bg-light border-0 shadow-sm">
                        <option value="">-- Select Session --</option>
                        @foreach (var s in sessions)
                        {
                            <option value="@s" selected="@(Context.Request.Query["session"].ToString() == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Class</label>
                    <select name="className" class="form-select bg-light border-0 shadow-sm">
                        <option value="">-- Select Class --</option>
                        @foreach (var c in classes)
                        {
                            <option value="@c" selected="@(Context.Request.Query["className"].ToString() == c)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Section</label>
                    <select name="section" class="form-select bg-light border-0 shadow-sm">
                        <option value="">-- All --</option>
                        @foreach (var s in sections)
                        {
                            <option value="@s" selected="@(Context.Request.Query["section"].ToString() == s)">@s</option>
                        }
                    </select>
                </div>
                @if (type != "EndOfYear")
                {
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">Term</label>
                        <select name="term" class="form-select bg-light border-0 shadow-sm">
                            <option value="">-- All Terms --</option>
                            @foreach (var t in terms)
                            {
                                <option value="@t" selected="@(Context.Request.Query["term"].ToString() == t)">@t</option>
                            }
                        </select>
                    </div>
                }
                <div class="col-md-2">
                    <button type="submit" class="btn btn-info text-white w-100 shadow-sm">
                        <i class="fas fa-search me-1"></i> Search
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Print-ready Report Cards -->
@if (Model != null && Model.Any())
{
    <div class="row g-4" id="printableArea">
        @foreach (var card in Model)
        {
            <div class="col-lg-6 mb-4 card-container">
                <div class="card border-0 shadow-sm h-100 report-card">
                    <div class="card-header bg-primary text-white py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0 fw-bold">@card.Name (@(card.RollNo ?? "No Roll#"))</h6>
                            <span class="badge bg-white text-primary">@card.Term - @type</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Subject</th>
                                    <th class="text-center">Total</th>
                                    <th class="text-center">Obtained</th>
                                    <th class="text-center">Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sub in card.Subjects)
                                {
                                    <tr>
                                        <td class="ps-3">@sub.Subject</td>
                                        <td class="text-center">@sub.TotalMarks</td>
                                        <td class="text-center fw-bold">@sub.ObtainedMarks</td>
                                        <td class="text-center">
                                            @{
                                                var pct = sub.TotalMarks > 0 ? (sub.ObtainedMarks / sub.TotalMarks * 100) : 0;
                                                var grade = pct >= 90 ? "A+" : pct >= 80 ? "A" : pct >= 70 ? "B" : pct >= 60 ? "C" : pct >= 50 ? "D" : "F";
                                            }
                                            <span class="fw-bold">@grade</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td class="ps-3">Overall Total</td>
                                    <td class="text-center">@card.TotalMarks</td>
                                    <td class="text-center">@card.TotalObtained</td>
                                    <td class="text-center">@card.Grade (@card.Percentage%)</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div class="card-footer bg-white border-top-0 py-4 d-none d-print-block">
                        <div class="d-flex justify-content-between align-items-end">
                            <div class="text-center border-top pt-2" style="width: 120px;"><small>Teacher</small></div>
                            <div class="text-center border-top pt-2" style="width: 120px;"><small>Principal</small></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Context.Request.Query.ContainsKey("session"))
{
    <div class="text-center py-5 text-muted bg-white rounded shadow-sm">
        <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
        <h5>No results found for the selected criteria.</h5>
    </div>
}
else
{
    <div class="text-center py-5 text-muted bg-white rounded shadow-sm">
        <i class="fas @icon fa-4x mb-3 opacity-25"></i>
        <h5>Select filters to generate report cards.</h5>
    </div>
}

<style>
    @@media print {
        .card-container { width: 50% !important; float: left; padding: 10px; page-break-inside: avoid; }
        .report-card { border: 1px solid #000 !important; }
        .bg-primary { background-color: #000 !important; color: #fff !important; }
        .table-light { background-color: #eee !important; }
    }
</style>
