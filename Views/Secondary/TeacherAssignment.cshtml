@model IEnumerable<StudentManagementSystem.Models.TeacherAssignment>
@{
    ViewData["Title"] = "Secondary Assignments";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">Secondary Assignments</h2>
            <p class="text-muted small">Create and manage student assignments. Expired assignments are hidden automatically.</p>
        </div>
        @if (User.IsInRole("Admin") || User.HasClaim("Permission", "Results.Manage"))
        {
            <button class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#assignmentModal">
                <i class="fas fa-plus-circle me-2"></i>Create New Assignment
            </button>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 rounded-3 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mx-1">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="mb-3">
                    <i class="fas fa-tasks fa-4x text-light"></i>
                </div>
                <h4 class="text-muted">No active assignments found.</h4>
                <p class="text-muted small">Create a new assignment to get started.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card border-0 shadow-sm h-100 assignment-card" style="border-radius: 15px;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
                                    @item.Subject
                                </span>
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3">
                                        <li><a class="dropdown-item small" href="javascript:void(0)" onclick="editAssignment(@Json.Serialize(item))">
                                            <i class="fas fa-edit me-2 text-warning"></i>Edit</a></li>
                                        <li>
                                            <form asp-action="DeleteAssignment" method="post" onsubmit="return confirm('Are you sure you want to delete this assignment?');">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="dropdown-item small text-danger">
                                                    <i class="fas fa-trash-alt me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            
                            <h5 class="fw-bold mb-2">@item.Title</h5>
                            <p class="text-muted small mb-4 text-truncate-2">@item.Description</p>
                            
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="small">
                                    <i class="fas fa-graduation-cap text-muted me-1"></i>
                                    <strong>@item.Class</strong> @item.Section
                                </div>
                                <div class="small ms-auto text-muted">
                                    <i class="fas fa-user-tie me-1"></i>@item.TeacherName
                                </div>
                            </div>

                            <hr class="opacity-25" />

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="small text-muted">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    Due: <span class="fw-bold @(item.EndDate.Date == DateTime.Today ? "text-danger" : "text-dark")">
                                        @item.EndDate.ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                                <div class="small">
                                    @{
                                        var daysLeft = (item.EndDate.Date - DateTime.Today).Days;
                                        var progressColor = daysLeft > 3 ? "bg-success" : (daysLeft > 1 ? "bg-warning" : "bg-danger");
                                    }
                                    <span class="badge @progressColor rounded-pill">
                                        @(daysLeft == 0 ? "Due Today" : daysLeft + " days left")
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Create/Edit Modal -->
<div class="modal fade" id="assignmentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow" style="border-radius: 20px;">
            <div class="modal-header bg-primary text-white py-4 px-5 border-0" style="border-radius: 20px 20px 0 0;">
                <h4 class="modal-title fw-bold" id="modalTitle">Create New Assignment</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SaveAssignment" method="post">
                <div class="modal-body p-5">
                    <input type="hidden" name="Id" id="assignmentId" value="0" />
                    
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">Assignment Title</label>
                            <input type="text" name="Title" id="title" class="form-control bg-light border-0 py-3" placeholder="Enter assignment title" required />
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea name="Description" id="description" class="form-control bg-light border-0" rows="3" placeholder="Details about the assignment..."></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Class</label>
                            <select name="Class" id="class" class="form-select bg-light border-0 py-3" required>
                                <option value="">Select Class</option>
                                @foreach (var c in ViewBag.Classes) { <option value="@c">@c</option> }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Section</label>
                            <select name="Section" id="section" class="form-select bg-light border-0 py-3">
                                <option value="">All Sections</option>
                                @foreach (var s in ViewBag.Sections) { <option value="@s">@s</option> }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Subject</label>
                            <input type="text" name="Subject" id="subject" class="form-control bg-light border-0 py-3" placeholder="e.g. Mathematics" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Teacher Name</label>
                            <input type="text" name="TeacherName" id="teacherName" class="form-control bg-light border-0 py-3" placeholder="Assigned Teacher" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Start Date</label>
                            <input type="date" name="StartDate" id="startDate" class="form-control bg-light border-0 py-3" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">End Date (Deadline)</label>
                            <input type="date" name="EndDate" id="endDate" class="form-control bg-light border-0 py-3" required value="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-5 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 py-2 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow">Save Assignment</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .assignment-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .assignment-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<script>
    function editAssignment(data) {
        document.getElementById('modalTitle').innerText = "Edit Assignment";
        document.getElementById('assignmentId').value = data.id;
        document.getElementById('title').value = data.title;
        document.getElementById('description').value = data.description;
        document.getElementById('class').value = data.class;
        document.getElementById('section').value = data.section;
        document.getElementById('subject').value = data.subject;
        document.getElementById('teacherName').value = data.teacherName;
        document.getElementById('startDate').value = data.startDate.split('T')[0];
        document.getElementById('endDate').value = data.endDate.split('T')[0];
        
        new bootstrap.Modal(document.getElementById('assignmentModal')).show();
    }

    // Reset modal on close
    document.getElementById('assignmentModal').addEventListener('hidden.bs.modal', function () {
        document.getElementById('modalTitle').innerText = "Create New Assignment";
        document.getElementById('assignmentId').value = "0";
        document.querySelector('form').reset();
    });
</script>
