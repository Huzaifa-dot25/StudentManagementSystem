@model StudentManagementSystem.Models.Student
@{
    Layout = "_Layout";
    ViewData["Title"] = "Student Profile - " + Model.Name;
}

<div class="print-container p-4 bg-white" id="printableProfile">
    <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
        <div>
            <h1 class="fw-bold text-primary mb-0">Student Profile</h1>
            <p class="text-muted">Academic Year: @(Model.Admission?.Session ?? "N/A")</p>
        </div>
        <div class="text-end">
            <h4 class="fw-bold mb-1">Student Management System</h4>
            <p class="small text-muted mb-0">Reg No: @(Model.Admission?.RollNo ?? "N/A")</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Photo and Basic Info -->
        <div class="col-3 text-center border-end">
            @if (!string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="@Model.PhotoPath" alt="Photo" class="img-thumbnail mb-3" style="width: 180px; height: 180px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 180px; height: 180px; border: 1px solid #dee2e6;">
                    <i class="fas fa-user fa-5x text-secondary"></i>
                </div>
            }
            <h5 class="fw-bold mb-1">@Model.Name</h5>
            <p class="text-muted small">ID: #@Model.StudentID</p>
            <div class="mt-3 p-2 bg-light rounded text-start">
                <div class="small fw-bold border-bottom mb-1 pb-1">Quick Status</div>
                <div class="small">Status: <span class="fw-bold text-success">@Model.Status</span></div>
                <div class="small">Admission: <span class="fw-bold">@Model.ApplicationStatus</span></div>
            </div>
        </div>

        <!-- Detailed Information -->
        <div class="col-9">
            <div class="row g-4">
                <div class="col-12">
                    <h6 class="bg-primary text-white p-2 rounded mb-3"><i class="fas fa-info-circle me-2"></i>Personal Information</h6>
                    <div class="row row-cols-2 g-3 px-2">
                        <div><span class="text-muted small d-block">Full Name</span> <span class="fw-bold">@Model.Name</span></div>
                        <div><span class="text-muted small d-block">Gender</span> <span class="fw-bold">@Model.Gender</span></div>
                        <div><span class="text-muted small d-block">Date of Birth</span> <span class="fw-bold">@Model.DateOfBirth.ToString("dd MMM yyyy")</span></div>
                        <div><span class="text-muted small d-block">Religion</span> <span class="fw-bold">@(Model.Religion ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Nationality</span> <span class="fw-bold">@(Model.InternationalDetail?.Nationality ?? "Local")</span></div>
                        <div><span class="text-muted small d-block">Address</span> <span class="fw-bold">@(Model.Address ?? "N/A")</span></div>
                    </div>
                </div>

                <div class="col-12">
                    <h6 class="bg-primary text-white p-2 rounded mb-3"><i class="fas fa-user-friends me-2"></i>Family Information</h6>
                    <div class="row row-cols-2 g-3 px-2">
                        <div><span class="text-muted small d-block">Father Name</span> <span class="fw-bold">@(Model.Parent?.FatherName ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Father CNIC</span> <span class="fw-bold">@(Model.Parent?.FatherNIC ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Mother Name</span> <span class="fw-bold">@(Model.Parent?.MotherName ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Parent Mobile</span> <span class="fw-bold">@(Model.Parent?.FatherMobile ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Guardian Name</span> <span class="fw-bold">@(Model.AdditionalInfo?.GuardianName ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Guardian Contact</span> <span class="fw-bold">@(Model.AdditionalInfo?.GuardianMobileNo ?? "N/A")</span></div>
                    </div>
                </div>

                <div class="col-12">
                    <h6 class="bg-primary text-white p-2 rounded mb-3"><i class="fas fa-school me-2"></i>Admission Details</h6>
                    <div class="row row-cols-2 g-3 px-2">
                        <div><span class="text-muted small d-block">Class</span> <span class="fw-bold">@(Model.Admission?.Class ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Section</span> <span class="fw-bold">@(Model.Admission?.Section ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Registration Date</span> <span class="fw-bold">@Model.RegistrationDate.ToString("dd MMM yyyy")</span></div>
                        <div><span class="text-muted small d-block">Admission Session</span> <span class="fw-bold">@(Model.Admission?.Session ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Blood Group</span> <span class="fw-bold">@(Model.MedicalDetail?.BloodGroup ?? "N/A")</span></div>
                        <div><span class="text-muted small d-block">Transport</span> <span class="fw-bold">@(Model.Transport?.BusNumber != null ? $"Bus {Model.Transport.BusNumber}" : "N/A")</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4 border-top">
        <div class="row text-center">
            <div class="col-4">
                <div class="border-top pt-2 mx-4"><small>Student Signature</small></div>
            </div>
            <div class="col-4">
                <div class="border-top pt-2 mx-4"><small>Parent Signature</small></div>
            </div>
            <div class="col-4">
                <div class="border-top pt-2 mx-4"><small>Authorized Signature</small></div>
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-4 no-print mb-5">
    <button onclick="window.print()" class="btn btn-primary btn-lg px-5">
        <i class="fas fa-print me-2"></i> Print Profile
    </button>
</div>

<style>
    @@media print {
        body { background-color: #fff !important; }
        .bg-primary { background-color: #0d6efd !important; -webkit-print-color-adjust: exact; color-adjust: exact; }
        .text-primary { color: #0d6efd !important; -webkit-print-color-adjust: exact; color-adjust: exact; }
        .print-container { padding: 0 !important; }
    }
</style>
