@model IEnumerable<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students List";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fas fa-info-circle me-2"></i>@TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="mb-0"><i class="fas fa-users me-2 text-primary"></i>Students</h2>
            <p class="text-muted small mb-0">Manage and search for students in the system</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="PrintList" asp-route-searchString="@ViewData["CurrentFilter"]" target="_blank" class="btn btn-outline-secondary px-4 shadow-sm">
                <i class="fas fa-print me-2"></i>Print List
            </a>
            <a asp-action="Create" class="btn btn-primary px-4 shadow-sm">
                <i class="fas fa-plus-circle me-2"></i>Add New Student
            </a>
        </div>
    </div>

    <!-- Search Section -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-8 col-lg-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                               class="form-control border-start-0" placeholder="Search by name or registration number..." />
                        <button type="submit" class="btn btn-primary px-4">Search</button>
                    </div>
                </div>
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
                    {
                        <a asp-action="Index" class="btn btn-link text-decoration-none">
                            <i class="fas fa-times me-1"></i> Clear Search
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Photo</th>
                            <th class="py-3">Reg No</th>
                            <th class="py-3">Name</th>
                            <th class="py-3">Gender</th>
                            <th class="py-3">Date of Birth</th>
                            <th class="text-end pe-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model) {
                                <tr class="align-middle">
                                    <td class="ps-4">
                                        @if (!string.IsNullOrEmpty(item.PhotoPath))
                                        {
                                            <img src="@item.PhotoPath" alt="Photo" class="rounded-circle shadow-sm" style="width: 45px; height: 45px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center text-primary" style="width: 45px; height: 45px;">
                                                <i class="fas fa-user"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border fw-500">
                                            @(item.Admission?.RollNo ?? "N/A")
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@item.StudentID" class="text-decoration-none text-dark fw-bold hover-primary">
                                            @item.Name
                                        </a>
                                    </td>
                                    <td>
                                        <span class="text-muted">@item.Gender</span>
                                    </td>
                                    <td>
                                        <span class="text-muted">@item.DateOfBirth.ToShortDateString()</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm">
                                            <a asp-controller="Fees" asp-action="Create" asp-route-studentId="@item.StudentID" class="btn btn-sm btn-white border" title="Create Fee Challan">
                                                <i class="fas fa-file-invoice-dollar text-success"></i>
                                            </a>
                                            <a asp-controller="Secondary" asp-action="StudentResults" asp-route-studentId="@item.StudentID" class="btn btn-sm btn-white border" title="View Results">
                                                <i class="fas fa-chart-bar text-primary"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.StudentID" class="btn btn-sm btn-white border" title="View Details">
                                                <i class="fas fa-eye text-info"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.StudentID" class="btn btn-sm btn-white border" title="Edit">
                                                <i class="fas fa-edit text-warning"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.StudentID" class="btn btn-sm btn-white border text-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                                    <p class="mb-0">No students found matching your search.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-primary:hover { color: var(--sidebar-active) !important; }
    .fw-500 { font-weight: 500; }
    .btn-white { background: #fff; color: #333; }
    .btn-white:hover { background: #f8f9fa; }
</style>

