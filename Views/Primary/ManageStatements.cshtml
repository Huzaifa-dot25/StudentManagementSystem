@model IEnumerable<StudentManagementSystem.Models.DescriptiveStatement>
@{
    ViewData["Title"] = "Primary - Manage Statements";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm" style="border-radius: 20px;">
    <div class="card-header bg-white py-4 px-4 border-0">
        <h4 class="mb-1 fw-bold text-dark"><i class="fas fa-comment-dots me-3 text-success"></i>Manage Descriptive Statements</h4>
        <p class="mb-0 text-muted small">Configure and assign performance comments for primary report cards.</p>
    </div>
    <div class="card-body p-4">
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="p-4 bg-light rounded-4 border-0 shadow-none">
                    <h6 class="fw-bold mb-3" id="formHeader">Add New Statement</h6>
                    
                    <form asp-action="SaveStatement" method="post" id="statementForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" id="statementId" value="0" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Category</label>
                            <select name="Category" id="statementCategory" class="form-select border-0 shadow-sm py-2" required>
                                <option value="Academic Performance">Academic Performance</option>
                                <option value="Behavioral Conduct">Behavioral Conduct</option>
                                <option value="Extracurricular">Extracurricular</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">Statement Text</label>
                            <textarea name="StatementText" id="statementText" class="form-control border-0 shadow-sm" rows="5" placeholder="e.g. Shows great interest in mathematics and logical reasoning." required></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success w-100 rounded-pill shadow-sm py-2" id="submitBtn">
                                <i class="fas fa-save me-2"></i>Save Statement
                            </button>
                            <button type="button" class="btn btn-secondary rounded-pill px-3 d-none" id="cancelBtn" onclick="resetForm()">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h6 class="fw-bold text-muted mb-0">EXISTING STATEMENTS <span class="badge bg-soft-success text-success ms-2">@Model.Count() Items</span></h6>
                    <form method="get" class="input-group input-group-sm" style="width: 280px;" id="searchForm">
                        <input type="text" name="search" id="searchInput" class="form-control border-0 bg-light" placeholder="Search statements..." value="@ViewBag.SearchQuery">
                        <button type="submit" class="btn btn-light border-0 bg-light"><i class="fas fa-search"></i></button>
                    </form>
                </div>
                <div class="table-responsive rounded-3 border bg-white">
                    <table class="table table-hover align-middle mb-0" id="statementsTable">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 180px;" class="ps-3">Category</th>
                                <th>Statement</th>
                                <th class="text-end pe-3" style="width: 100px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    var badgeClass = item.Category switch
                                    {
                                        "Academic Performance" => "bg-soft-success text-success",
                                        "Behavioral Conduct" => "bg-soft-info text-info",
                                        _ => "bg-soft-warning text-warning"
                                    };
                                    <tr class="statement-row">
                                        <td class="ps-3">
                                            <span class="badge @badgeClass fw-bold py-2 px-3 rounded-pill category-badge">@item.Category</span>
                                        </td>
                                        <td class="small text-dark text-wrap statement-content">@item.StatementText</td>
                                        <td class="text-end pe-3">
                                            <div class="d-flex justify-content-end gap-1">
                                                <button class="btn btn-link btn-sm text-primary p-1 btn-edit-statement"
                                                        data-id="@item.Id"
                                                        data-category="@item.Category"
                                                        data-statement="@item.StatementText"
                                                        title="Edit statement">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <form asp-action="DeleteStatement" method="post" onsubmit="return confirm('Are you sure you want to delete this statement?')" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-danger p-1" title="Delete statement">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5 text-muted">
                                        <i class="fas fa-folder-open fa-3x mb-3 text-light"></i>
                                        <p class="mb-0">No statements found.</p>
                                        @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
                                        {
                                            <p class="small text-muted">Try clearing the search filter.</p>
                                        }
                                        else
                                        {
                                            <p class="small text-muted">Add a new descriptive statement to get started.</p>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    .form-select:focus, .form-control:focus { box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.15); border-color: #198754; }
    .rounded-4 { border-radius: 1rem !important; }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Edit Statement Hook
        const editButtons = document.querySelectorAll(".btn-edit-statement");
        editButtons.forEach(btn => {
            btn.addEventListener("click", function () {
                const id = this.getAttribute("data-id");
                const category = this.getAttribute("data-category");
                const statement = this.getAttribute("data-statement");

                document.getElementById("statementId").value = id;
                document.getElementById("statementCategory").value = category;
                document.getElementById("statementText").value = statement;

                document.getElementById("formHeader").innerText = "Edit Statement";
                document.getElementById("submitBtn").innerHTML = '<i class="fas fa-save me-2"></i>Update Statement';
                document.getElementById("submitBtn").className = "btn btn-primary w-100 rounded-pill shadow-sm py-2";
                document.getElementById("cancelBtn").classList.remove("d-none");

                // Scroll to form on small screens
                document.getElementById("statementForm").scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
        });

        // Client-side quick search filter
        const searchInput = document.getElementById("searchInput");
        if (searchInput) {
            searchInput.addEventListener("input", function () {
                const term = this.value.toLowerCase().trim();
                const rows = document.querySelectorAll("#statementsTable tbody tr.statement-row");
                
                rows.forEach(row => {
                    const category = row.querySelector(".category-badge").innerText.toLowerCase();
                    const statement = row.querySelector(".statement-content").innerText.toLowerCase();
                    
                    if (category.includes(term) || statement.includes(term)) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                });
            });
        }
    });

    function resetForm() {
        document.getElementById("statementId").value = "0";
        document.getElementById("statementCategory").selectedIndex = 0;
        document.getElementById("statementText").value = "";

        document.getElementById("formHeader").innerText = "Add New Statement";
        document.getElementById("submitBtn").innerHTML = '<i class="fas fa-save me-2"></i>Save Statement';
        document.getElementById("submitBtn").className = "btn btn-success w-100 rounded-pill shadow-sm py-2";
        document.getElementById("cancelBtn").classList.add("d-none");
    }
</script>
