@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-sm p-5" style="border-radius: 20px;">
                <div class="mb-4">
                    <i class="fas fa-lock fa-5x text-danger opacity-50"></i>
                </div>
                <h1 class="display-5 fw-bold text-dark">Access Denied</h1>
                <p class="lead text-muted mb-4">You do not have permission to view this page. Please contact your administrator if you believe this is an error.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/" class="btn btn-primary rounded-pill px-4 py-2">Go to Dashboard</a>
                    <a href="/Account/Login" class="btn btn-outline-secondary rounded-pill px-4 py-2">Login as Admin</a>
                </div>
            </div>
        </div>
    </div>
</div>
